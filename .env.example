# NeuralSight: Max - Environment Configuration Example
# ==================================================
# Rename this file to .env and fill in your actual keys.

# 1. Groq API (Transcription)
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# 2. OpenClaude / MiniMax (Agent Brain)
# If using MiniMax via Anthropic-compatible endpoint:
ANTHROPIC_API_KEY=your_minimax_key_here
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic

# 3. Optional: Picovoice (Alternative Wake Word)
# PICOVOICE_API_KEY=your_key_here
